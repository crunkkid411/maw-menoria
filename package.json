{
  "name": "@memvid/maw",
  "version": "1.0.3",
  "description": "Crawl any site. Search it forever.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "maw": "dist/bin/maw.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memvid/maw.git"
  },
