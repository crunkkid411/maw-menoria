    "@mozilla/readability": "^0.5.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "cliui": "^9.0.1",
    "commander": "^12.0.0",
    "jsdom": "^24.0.0",
    "node-html-markdown": "^1.3.0",
    "p-queue": "^8.0.0",
    "sitemapper": "^4.0.2"
  },
  "optionalDependencies": {
    "playwright": "^1.47.0",
    "rebrowser-playwright": "^1.47.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.0.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
